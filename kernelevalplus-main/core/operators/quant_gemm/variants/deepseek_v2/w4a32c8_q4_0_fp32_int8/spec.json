{
  "name": "w4a32c8_q4_0_fp32_int8",
  "variant": "W4A32C8",
  "family": "quant_gemm",
  "version": "1.0.0",
  "description": "DeepSeek-V2 W4A32C8 Quantized GEMM: 4-bit weights (Q4_0), FP32 activations (dynamically quantized to Q8_1 style), 8-bit compute (INT8). Matches llama.cpp Q4_0\u00d7Q8_1 pattern.",
  "model_architectures": [
    "deepseek-v2"
  ],
  "tags": [
    "status:verified",
    "framework:deepseek",
    "source:llama.cpp",
    "quantization:q4_0",
    "quantization:q8_1"
  ],
  "kernel": {
    "file": "kernel.cu",
    "entry_point": "forward"
  },
  "inputs": {
    "weight": {
      "dtype": "block_q4_0",
      "shape": [
        "N",
        "K/32",
        18
      ],
      "description": "Q4_0 quantized weight tensor [output_features, num_blocks, 18 bytes/block]",
      "quantizer": "quantize_q4_0"
    },
    "activation": {
      "dtype": "float32",
      "shape": [
        "M",
        "K"
      ],
      "description": "FP32 activation tensor [batch, input_features], dynamically quantized to Q8_1 style in kernel"
    }
  },
  "outputs": {
    "output": {
      "dtype": "float32",
      "shape": [
        "M",
        "N"
      ],
      "description": "FP32 output tensor [batch, output_features]"
    }
  },
  "params": {
    "M": {
      "type": "int",
      "description": "Batch dimension (batch_size * seq_len)",
      "constraint": "M >= 1"
    },
    "N": {
      "type": "int",
      "default": 5120,
      "description": "Output features (model hidden_size for DeepSeek-V2)"
    },
    "K": {
      "type": "int",
      "default": 5120,
      "description": "Input features (must be multiple of 32)",
      "constraint": "K % 32 == 0"
    }
  },
  "reference": "reference.py:run",
  "test_configs": [
    {
      "name": "batch_1",
      "M": 1,
      "description": "Single token inference"
    },
    {
      "name": "batch_2",
      "M": 2,
      "description": "Small batch (2)"
    },
    {
      "name": "batch_3",
      "M": 3,
      "description": "Small batch (3)"
    },
    {
      "name": "batch_4",
      "M": 4,
      "description": "Small batch (4)"
    },
    {
      "name": "batch_5",
      "M": 5,
      "description": "Small batch (5)"
    },
    {
      "name": "batch_8",
      "M": 8,
      "description": "Small batch (8)"
    },
    {
      "name": "batch_512",
      "M": 512,
      "description": "Large batch inference"
    }
  ],
  "accuracy": {
    "metric": "nmse",
    "threshold": 0.1
  },
  "formula": {
    "computation": "1. Dynamically quantize A to Q8_1 style (per-block scale), 2. INT8 GEMM with Q4_0 weights, 3. Apply offset compensation",
    "dequantize": "w = (qs - 8) * scale_w, a = qs * scale_a",
    "gemm": "C[m,n] = sum_k(w_qs[n,k] * a_qs[m,k]) * d_w * d_a - 8 * s_a * d_w"
  },
  "llama_cpp_pattern": {
    "weight_format": "Q4_0",
    "activation_format": "Q8_1 style (dynamic quantization)",
    "compute": "vec_dot_q4_0_q8_1_dp4a",
    "formula": "d4_0 * (d8_1 * sumi - 8 * s8_1)"
  },
  "notes": [
    "Matches llama.cpp Q4_0 \u00d7 Q8_1 pattern (d4_0 * (d8_1 * sumi - 8 * s8_1))",
    "Q4_0 uses offset-8 encoding (values 0-15 stored, representing -8 to +7)",
    "The -8*s8_1 term compensates for the offset in Q4_0 encoding",
    "Per-block activation quantization (32 values per block)",
    "INT8 compute provides 2-4x speedup over FP32"
  ]
}